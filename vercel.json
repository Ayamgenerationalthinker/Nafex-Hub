{
  "buildCommand": "pnpm run typecheck:libs && pnpm --filter @workspace/db run push && pnpm --filter @workspace/api-server run build:vercel && pnpm --filter @workspace/nafex-hub run build",
  "outputDirectory": "artifacts/nafex-hub/dist/public",
  "installCommand": "pnpm install",
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/vercel-handler" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
