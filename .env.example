# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# PostgreSQL (Railway / local Docker / Neon)
DATABASE_URL=postgresql://user:password@localhost:5432/nafexhub

# Frontend origin for API CORS (production Railway / custom domain)
# Vercel deploys frontend+API on same domain — often not needed there.
ALLOWED_ORIGIN=http://localhost:3000

# ── Payments (Paystack) ──────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxx

# ── Email (verification + admin alerts) ──────────────────────────────────────
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password
ADMIN_EMAIL=admin@example.com

# Legacy SMTP names (optional if EMAIL_* set)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password

# ── Image uploads (optional — local /uploads used if unset) ─────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── AI listing optimizer (optional — rule-based fallback if unset) ───────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Frontend dev (Vite) ──────────────────────────────────────────────────────
# PORT=3000
# API_PROXY_TARGET=http://127.0.0.1:5000
